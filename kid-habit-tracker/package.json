{
  "name": "kid-habit-tracker",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:pilot:android": "bash scripts/build-pilot-android.sh",
    "build:pilot:ios": "bash scripts/build-pilot-ios.sh",
    "lint": "expo lint",
    "verify:schema": "node scripts/verify-schema.js",
    "verify:no-tracking": "node scripts/verify-no-tracking.js",
    "verify:protected-storage-access": "node scripts/verify-protected-storage-access.js",
    "verify:streak-dispute-diagnostics": "node scripts/verify-streak-dispute-diagnostics.js",
    "verify:phase2-compliance-extension": "node scripts/verify-phase2-compliance-extension-points.js",
    "verify:pilot-channel-setup": "node scripts/verify-pilot-channel-setup.js",
    "verify:pilot-smoke": "node scripts/verify-pilot-smoke-gate.js",
    "verify:build-reproducibility": "node scripts/verify-build-reproducibility.js --channel=pilot",
    "verify:phase2-store-readiness-scaffold": "node scripts/verify-phase2-store-readiness-scaffold.js",
    "verify:release-gate": "npm run verify:privacy && npm run verify:pilot-channel-setup && npm run verify:pilot-smoke",
    "verify:runtime-egress": "node scripts/verify-runtime-no-egress.js",
    "verify:privacy": "npm run verify:schema && npm run verify:no-tracking && npm run verify:protected-storage-access && npm run verify:streak-dispute-diagnostics && npm run verify:phase2-compliance-extension && npm run verify:runtime-egress"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-notifications": "^55.0.20",
    "expo-secure-store": "^55.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
