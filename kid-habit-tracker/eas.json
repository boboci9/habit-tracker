{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_RELEASE_CHANNEL": "dev",
        "PHASE2_FEATURES_ENABLED": "false"
      }
    },
    "pilot-android": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_RELEASE_CHANNEL": "pilot",
        "PHASE2_FEATURES_ENABLED": "false"
      }
    },
    "pilot-ios": {
      "distribution": "store",
      "ios": {
        "simulator": false
      },
      "env": {
        "APP_RELEASE_CHANNEL": "pilot",
        "PHASE2_FEATURES_ENABLED": "false"
      }
    }
  }
}
